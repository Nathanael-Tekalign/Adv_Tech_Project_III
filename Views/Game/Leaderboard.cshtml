@model IEnumerable<TriviaGame.Models.Player>

@{
    ViewData["Title"] = "Leaderboard";
}

<h1>Leaderboard</h1>

<p><strong>Room Code:</strong> @ViewBag.RoomCode</p>

<table class="table">
    <thead>
        <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Score</th>
            <th>Average Time</th>
        </tr>
    </thead>
    <tbody>
        @{
            int rank = 1;
        }
        @foreach (var player in Model)
        {
            var avgTime = player.PlayerAnswers != null && player.PlayerAnswers.Any()
                ? player.PlayerAnswers.Average(a => a.TimeTakenSeconds).ToString("F1") + "s"
                : "N/A";

            var isWinner = rank == 1;

        <tr class="@(isWinner ? "table-warning fw-bold" : "")">
            <td>
                @if (isWinner)
                    {
                <span>1. Winner!</span>
                    }
                    else
                    {
                @rank
                    }
            </td>
            <td>@player.Name</td>
            <td>@player.TotalScore pts</td>
            <td>@avgTime</td>
        </tr>
            rank++;
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="Game" asp-action="Start" class="btn btn-primary">Play Again</a>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Back Home</a>
</div>